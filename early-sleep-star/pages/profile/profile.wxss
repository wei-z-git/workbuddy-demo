/* ===== 个人中心特有样式 ===== */

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px;
  gap: 10px;
}

.profile-avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--clr-night), var(--clr-night-light));
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
}

.profile-name {
  font-size: 18px;
  font-weight: 700;
  color: var(--clr-night);
}

.profile-title-badge {
  padding: 4px 14px;
  border-radius: 16px;
  background: var(--clr-accent-soft);
  color: var(--clr-accent);
  font-size: 12px;
  font-weight: 600;
}

/* ===== 进度信息 ===== */
.progress-info {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: var(--clr-text-secondary);
  margin-bottom: 4px;
}

/* ===== 勋章墙 ===== */
.medal-wall {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  padding: 4px 0;
}

.medal-item {
  text-align: center;
  flex-shrink: 0;
}

.medal-icon {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
}

.medal-label {
  font-size: 10px;
  color: var(--clr-text-secondary);
  margin-top: 4px;
}
