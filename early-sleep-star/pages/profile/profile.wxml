<view class="page-body">

  <!-- 个人信息 -->
  <view class="profile-header">
    <view class="profile-avatar">{{userInfo.avatarLetter}}</view>
    <view class="profile-name">{{userInfo.nickname}}</view>
    <view class="profile-title-badge">{{titleInfo.icon}} {{titleInfo.name}}</view>
  </view>

  <!-- 统计网格 -->
  <view class="stat-grid">
    <view wx:for="{{stats}}" wx:key="label" class="stat-item">
      <view class="stat-value">{{item.value}}</view>
      <view class="stat-label">{{item.label}}</view>
    </view>
  </view>

  <!-- 称号升级进度 -->
  <view class="card">
    <view class="card-title" style="margin-bottom:8px;">称号升级进度</view>
    <view class="progress-info">
      <view class="progress-current">{{titleInfo.icon}} {{titleInfo.name}}</view>
      <view class="progress-next" wx:if="{{titleInfo.nextThreshold}}">
        {{totalCoins}} / {{titleInfo.nextThreshold}} → 💫 早睡之星
      </view>
    </view>
    <view class="progress-bar-wrap">
      <view class="progress-bar-fill" style="width:{{progressPercent}}%;"></view>
    </view>
  </view>

  <!-- 勋章墙 -->
  <view class="card">
    <view class="card-header">
      <view class="card-title">🏅 勋章墙</view>
    </view>
    <view class="medal-wall">
      <view wx:for="{{medals}}" wx:key="cycleId" class="medal-item" style="opacity:{{item.opacity}};">
        <view class="medal-icon" style="background:linear-gradient(135deg, {{item.gradientStr}});">
          {{item.displayIcon}}
        </view>
        <view class="medal-label">{{item.cycleNumber === 3 && !item.earned ? '待解锁' : '第' + item.cycleNumber + '轮'}}</view>
      </view>
    </view>
  </view>

  <!-- 菜单 -->
  <view class="menu-list">
    <view wx:for="{{menuItems}}" wx:key="action"
      class="menu-item"
      data-action="{{item.action}}"
      bindtap="onMenuTap">
      <view class="menu-item-left">
        <view class="menu-icon">{{item.icon}}</view>
        <view class="menu-text">{{item.text}}</view>
      </view>
      <view class="menu-right">{{item.right}}</view>
    </view>
  </view>

</view>
