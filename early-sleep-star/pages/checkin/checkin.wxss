/* ===== 打卡页特有样式 ===== */

.time-card {
  text-align: center;
  padding: 24px;
}

.time-display {
  font-size: 48px;
  font-weight: 300;
  color: var(--clr-night);
  font-family: var(--font-mono);
  margin-bottom: 4px;
}

.time-label {
  font-size: 12px;
  color: var(--clr-text-secondary);
}

.period-badge {
  margin-top: 12px;
  padding: 8px 16px;
  border-radius: 20px;
  display: inline-block;
  font-size: 13px;
  font-weight: 600;
}

.period-badge.gold {
  background: #e8f5e9;
  color: var(--clr-success);
}

.period-badge.late {
  background: #fff8e1;
  color: var(--clr-warning);
}

.period-badge.fail {
  background: #ffebee;
  color: var(--clr-error);
}

.period-badge.not_in_window {
  background: #f5f5f5;
  color: var(--clr-text-muted);
}

/* ===== 打卡环形按钮（大版） ===== */
.checkin-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8px 0 12px;
}

.checkin-ring {
  width: 160px;
  height: 160px;
  border-radius: 50%;
  position: relative;
  margin-bottom: 16px;
}

.checkin-ring.disabled .checkin-ring-inner {
  background: linear-gradient(135deg, #9e9e9e, #757575);
}

.checkin-ring-outer {
  position: absolute;
  top: -6px;
  left: -6px;
  right: -6px;
  bottom: -6px;
  border-radius: 50%;
  background: conic-gradient(var(--clr-accent) 0deg, var(--clr-accent) 180deg, transparent 180deg);
  opacity: 0.2;
}

.checkin-ring-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #2d3b5a 0%, #1e2a3a 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  position: relative;
  z-index: 1;
}

.moon-icon.large {
  font-size: 44px;
}

.checkin-text.large {
  font-size: 18px;
}

.checkin-ring:active .checkin-ring-inner {
  transform: scale(0.95);
}

/* ===== 睡前小问预览 ===== */
.question-preview {
  text-align: center;
}

.question-preview-text {
  font-size: 14px;
  color: var(--clr-text-secondary);
  margin-bottom: 4px;
}

.question-preview-hint {
  font-size: 12px;
  color: var(--clr-text-muted);
}

/* ===== 打卡历史列表 ===== */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.history-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
}

.history-row.has-border {
  border-bottom: 1px solid var(--clr-border);
}

.history-day {
  font-size: 14px;
}

.history-result {
  font-size: 14px;
}

/* ===== 请假 ===== */
.leave-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.leave-info {
  flex: 1;
}

.leave-arrow {
  font-size: 13px;
}

/* ===== 弹窗内容 ===== */
.question-text {
  text-align: center;
  font-size: 15px;
  color: var(--clr-night);
  margin-bottom: 16px;
}

.question-options {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.question-option {
  text-align: center;
}

.question-hint {
  text-align: center;
  font-size: 11px;
  color: var(--clr-text-muted);
  margin-top: 12px;
}

/* ===== 请假弹窗 ===== */
.leave-modal-content {
  text-align: center;
  font-size: 14px;
  color: var(--clr-text-secondary);
  margin-bottom: 16px;
}

.leave-modal-warning {
  font-size: 12px;
  color: var(--clr-warning);
  text-align: center;
  margin-bottom: 12px;
}

.cancel-btn {
  margin-top: 8px;
}
