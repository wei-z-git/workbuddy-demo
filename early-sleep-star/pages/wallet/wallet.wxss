/* ===== 钱包页特有样式 ===== */

.balance-card {
  background: linear-gradient(135deg, #2d3b5a, #1e2a3a);
  color: #ffffff;
  text-align: center;
  padding: 24px;
}

.balance-label {
  font-size: 12px;
  opacity: 0.7;
  margin-bottom: 4px;
}

.balance-value {
  font-size: 40px;
  font-weight: 700;
}

.withdraw-btn {
  margin-top: 12px;
  background: var(--clr-accent);
  color: #ffffff;
}

.balance-hint {
  font-size: 10px;
  opacity: 0.5;
  margin-top: 8px;
}

/* ===== 押金明细 ===== */
.deposit-detail {
  display: flex;
  flex-direction: column;
}

.deposit-row {
  display: flex;
  justify-content: space-between;
  padding: 6px 0;
  font-size: 13px;
  color: var(--clr-text-secondary);
}

.deposit-row.bold {
  font-weight: 600;
}

.deposit-label {
  flex: 1;
}

.deposit-value {
  text-align: right;
}

/* ===== 交易明细 ===== */
.transaction-list {
  display: flex;
  flex-direction: column;
}

.transaction-row {
  display: flex;
  justify-content: space-between;
  padding: 4px 0;
  font-size: 12px;
  color: var(--clr-text-secondary);
}

.transaction-row.has-border {
  border-bottom: 1px solid var(--clr-border);
}

.transaction-label {
  flex: 1;
}

.transaction-amount {
  text-align: right;
  font-weight: 600;
}
