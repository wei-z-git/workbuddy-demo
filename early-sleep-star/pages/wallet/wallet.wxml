<view class="page-body">

  <!-- 余额卡片 -->
  <view class="card balance-card">
    <view class="balance-label">可提现余额</view>
    <view class="balance-value">¥{{rewardBalance}}</view>
    <view class="btn btn-primary btn-large withdraw-btn" bindtap="onWithdraw">提现至微信余额</view>
    <view class="balance-hint">最低提现 1 元 · 免手续费</view>
  </view>

  <!-- 当前押金状态 -->
  <view class="card">
    <view class="card-header">
      <view class="card-title">本轮押金状态 · 第{{cycleNumber}}轮</view>
    </view>
    <view class="deposit-detail">
      <view class="deposit-row">
        <view class="deposit-label">已缴押金</view>
        <view class="deposit-value">¥{{depositInfo.paid}}.00</view>
      </view>
      <view class="deposit-row">
        <view class="deposit-label">累计扣罚</view>
        <view class="deposit-value" style="color:var(--clr-error);">-¥{{depositInfo.penalty}}.00</view>
      </view>
      <view class="deposit-row bold">
        <view class="deposit-label">预计退还</view>
        <view class="deposit-value" style="color:var(--clr-success);">¥{{depositInfo.refund}}.00</view>
      </view>
    </view>
  </view>

  <!-- 历史明细 -->
  <view class="card">
    <view class="card-header">
      <view class="card-title">历史明细</view>
    </view>
    <view class="transaction-list">
      <view wx:for="{{transactions}}" wx:key="id"
        class="transaction-row {{item.id !== transactions[transactions.length-1].id ? 'has-border' : ''}}">
        <view class="transaction-label">{{item.label}}</view>
        <view class="transaction-amount" style="color:{{item.color}};">{{item.amountStr}}</view>
      </view>
    </view>
  </view>

</view>
