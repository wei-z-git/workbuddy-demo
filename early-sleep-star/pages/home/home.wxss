/* ===== 首页特有样式 ===== */

.today-status-card {
  background: linear-gradient(135deg, #fff8e1 0%, #ffffff 50%, #fff3e0 100%);
}

.today-status-content {
  text-align: center;
  padding: 4px 0;
}

.today-emoji {
  font-size: 32px;
  margin-bottom: 4px;
}

.today-hint {
  font-size: 14px;
  color: var(--clr-text-secondary);
}

/* ===== 打卡环形按钮 ===== */
.checkin-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8px 0 12px;
}

.checkin-ring {
  width: 140px;
  height: 140px;
  border-radius: 50%;
  position: relative;
  margin-bottom: 16px;
}

.checkin-ring-outer {
  position: absolute;
  top: -6px;
  left: -6px;
  right: -6px;
  bottom: -6px;
  border-radius: 50%;
  background: conic-gradient(var(--clr-accent) 0deg, var(--clr-accent) 180deg, transparent 180deg);
  opacity: 0.2;
}

.checkin-ring-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #2d3b5a 0%, #1e2a3a 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  position: relative;
  z-index: 1;
}

.moon-icon {
  font-size: 36px;
  margin-bottom: 4px;
}

.checkin-text {
  font-size: 15px;
  font-weight: 700;
}

.checkin-sub {
  font-size: 11px;
  opacity: 0.7;
  margin-top: 2px;
}

.checkin-ring:active .checkin-ring-inner {
  transform: scale(0.95);
}

/* ===== 热力图列 ===== */
.heatmap-col {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

/* ===== 群动态 ===== */
.group-activity {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.activity-row {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
}

.activity-text {
  flex: 1;
}

.activity-emoji {
  font-weight: 600;
}

/* ===== 提醒 ===== */
.reminder-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.reminder-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.reminder-info {
  flex: 1;
}

.reminder-status {
  font-size: 13px;
  font-weight: 600;
}

/* ===== 7天进度 ===== */
.round-progress {
  display: flex;
  gap: 4px;
  margin-top: 8px;
}
