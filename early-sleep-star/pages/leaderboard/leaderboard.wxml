<view class="page-body">

  <!-- 排行Tab -->
  <view class="lb-tabs">
    <view wx:for="{{tabs}}" wx:key="key"
      class="lb-tab {{activeTab === item.key ? 'active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onTabChange">
      {{item.label}}
    </view>
  </view>

  <!-- Top 3 -->
  <view class="card" style="padding-bottom:8px;">
    <view class="card-header">
      <view class="card-title">🥇 本周 Top 3</view>
    </view>
    <view class="lb-top3">
      <view wx:for="{{top3}}" wx:key="rankClass" class="lb-podium {{item.rankClass}}">
        <view class="podium-avatar">{{item.avatarLetter}}</view>
        <view class="podium-name">{{item.nickname}}</view>
        <view class="podium-coins">{{item.coins}}</view>
        <view class="podium-title-badge">{{item.titleIcon}} {{item.titleName}}</view>
      </view>
    </view>
  </view>

  <!-- 完整排名列表 -->
  <view class="card" style="padding:0;overflow:hidden;">
    <view wx:for="{{leaderboardList}}" wx:key="rank"
      class="lb-row {{item.isMe ? 'me' : ''}}">
      <view class="lb-rank" style="color:{{item.rankColor}};">{{item.rank}}</view>
      <view class="lb-avatar-small">{{item.avatarLetter}}</view>
      <view class="lb-info">
        <view class="lb-name" style="{{item.isMe ? 'color:var(--clr-accent);' : ''}}">
          {{item.isMe ? '我' : item.nickname}}
        </view>
        <view class="lb-heat" wx:if="{{item.heatDots.length > 0}}">
          <view wx:for="{{item.heatDots}}" wx:for-item="dot" wx:key="*this"
            class="lb-heat-dot {{dot}}"></view>
        </view>
      </view>
      <view class="lb-score">{{item.score}}{{item.scoreLabel || ''}}</view>
    </view>
  </view>

</view>
